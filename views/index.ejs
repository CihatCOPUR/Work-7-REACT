<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo App</title>
</head>
<body>
    <h1>Todo List</h1>
    <form action="/add" method="POST">
        <input type="text" name="todo" placeholder="Add a new todo">
        <button type="submit">Add</button>
    </form>
    <ul>
        <% todos.forEach(todo => { %>
            <li><%= todo %></li>
        <% }); %>
    </ul>
</body>
</html>
